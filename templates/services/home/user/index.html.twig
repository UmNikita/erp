{% extends 'layout/index.html.twig' %}

{% block content %}
<div class="top">
  <div class="title">
    <h1>Команда и доступы</h1>
    <p>Управление сотрудниками и доступом к рабочим разделам. Здесь отображаются только реальные пользователи системы.</p>
  </div>
  <div class="top-actions">
    <input class="search js-user-search" placeholder="Поиск по имени, email, роли...">
    <a class="btn" href="{{ path('app_home_users_new') }}">+ Добавить пользователя</a>
  </div>
</div>

<section class="grid compact-grid">
  <div class="card metric">
    <small>Пользователи</small>
    <strong>{{ userCount }}</strong>
    <span class="badge">реальные данные</span>
  </div>
  <div class="card metric">
    <small>Рабочие разделы</small>
    <strong>10</strong>
    <span class="badge">доступы</span>
  </div>
</section>

<h2 class="section-title">Пользователи</h2>

<div class="table-wrap">
  <table class="js-users-table">
    <thead>
      <tr>
        <th>Пользователь</th>
        <th>Отдел</th>
        <th>Статус</th>
        <th>Создан</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      {% for user in users %}
        <tr data-user="{{user.id}}">
          <td>
            <div class="user-cell">
              <div class="avatar-small">{{ user.firstLetter }}</div>
              <div>
                <b class="user-t-name">{{ user.name }}</b>
                <div class="muted user-t-email">{{ user.email }}</div>
              </div>
            </div>
          </td>
          <td class="user-t-department">{{ user.department }}</td>
          <td>
            {% if user.isActive %}
                <span class="status">Активен</span>
            {% else %}
                <span class="status off">Диактивирован</span>
            {% endif %}
          </td>
          <td class="muted user-t-datetime">{{user.datetime}}</td>
          <td>
            <div class="row-actions">
              <a class="btn secondary btn-sm user-t-btn-e" href="{{ path('app_home_users_edit', {id: user.id}) }}">Изменить</a>
              <a class="btn secondary btn-sm user-t-btn-p" href="{{ path('app_home_users_password', {id: user.id})}}">Пароль</a>
              {% if user.id == user_service.user.id %}
                  <span class="muted user-t-btn-current">Текущий аккаунт</span>
              {% else %}
                {% if user.isActive %}
                  <button type="button" class="btn secondary btn-sm js-toggle-user">Отключить</button> 
                {% else %}
                  <span class="muted user-t-btn-current">Аккаунт деактивирован</span>
                {% endif %}
              {% endif %}
            </div>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<h2 class="section-title">Отделы</h2>
<a class="btn" href="{{path('app_home_users_departments_new')}}">+ Добавить отдел</a>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Название</th>
        <th>Количество пользователей в отделе</th>
      </tr>
    </thead>
    <tbody>
      {% for department in departments %}
        <tr data-id="{{ department.id }}">
            <td>
              <b>{{ department.name }}</b>
            </td>
            <td>
              <b>{{ department.userCount }}</b>
            </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<h2 class="section-title">Роли</h2>
<a class="btn" href="{{path('app_home_users_roles_new')}}">+ Добавить роль</a>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Название</th>
      </tr>
    </thead>
    <tbody>
        <tr data-user-row data-search="">
            {% for role in roles %}
              <tr data-id="{{ role.id }}">
                  <td>
                    <b>{{ role.name }}</b>
                  </td>
              </tr>
            {% endfor %}
        </tr>
    </tbody>
  </table>
</div>

<h2 class="section-title">Матрица доступа к сервисам</h2>

<section class="card info-card">
  <b>Как работает доступ</b>
  <p>
    Если переключатель включён — сервис появляется у пользователя  в первом левом меню.
    Если выключен — пользователь с ролью не видит сервис и не может открыть его напрямую.
  </p>
</section>

<div class="table-wrap access-matrix">
  <table>
    <thead>
      <tr>
        <th>Роль</th>
        <th>CRM</th>
        <th>Репостер</th>
        <th>Сайт</th>
        <th>Статьи</th>
        <th>Партнёрки</th>
        <th>Статистика</th>
        <th>Задачи</th>
        <th>Прозвон</th>
        <th>Базы</th>
        <th>AI</th>
      </tr>
    </thead>
    <tbody>
        {% for role in roleMatrix %}
          <tr data-id="{{ role.id }}">
            <td>
                <b>{{ role.name }}</b>
            </td>
            {% if role.crm %}
              <td class="crm">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="crm">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.repost %}
              <td class="repost">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="repost">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.site %}
              <td class="site">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="site">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.article %}
              <td class="article">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="article">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.partner %}
              <td class="partner">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="partner">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.statistic %}
              <td class="statistic">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="statistic">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.task %}
              <td class="task">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="task">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.call %}
              <td class="call">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="call">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.base %}
              <td class="base">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="base">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
            {% if role.ai %}
              <td class="ai">
                <button
                  type="button"
                  class="toggle on"
                  data-value="true"
                  title="Отключить">
                </button>
              </td>
            {% else %}
              <td class="ai">
                <button
                  type="button"
                  class="toggle"
                  data-value="false"
                  title="Включить">
                </button>
              </td>
            {% endif %}
          </tr>
        {% endfor %}
    </tbody>
  </table>
</div>

<script src="{{ asset('js/users.js') }}" defer></script>

{% endblock %}