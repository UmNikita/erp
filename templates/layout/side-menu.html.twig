{% set route = app.request.attributes.get('_route') %}

<aside class="rail">
  <div class="logo">RH</div>

  <div class="rail-nav">
    <a class="rail-btn {{ route starts with 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}" data-tip="Главная">
      <svg viewBox="0 0 24 24"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10.5V20h14v-9.5"/><path d="M9 20v-6h6v6"/></svg>
    </a>
    {% if is_granted(enum('App\\Security\\Enum\\Permission').CRM_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_crm' ? 'active' : '' }}" href="{{ path('app_crm') }}" data-tip="CRM">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="3"/><path d="M3 10h18"/><path d="M9 10v10"/><path d="M15 10v10"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').REPOST_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_repost' ? 'active' : '' }}" href="{{ path('app_repost') }}" data-tip="Репостер">
        <svg viewBox="0 0 24 24"><path d="M17 2l4 4-4 4"/><path d="M3 11V9a3 3 0 0 1 3-3h15"/><path d="M7 22l-4-4 4-4"/><path d="M21 13v2a3 3 0 0 1-3 3H3"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').SITE_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_site' ? 'active' : '' }}" href="{{ path('app_site') }}" data-tip="Сайт">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18"/><path d="M12 3a14 14 0 0 0 0 18"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').ARTICLE_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_article' ? 'active' : '' }}" href="{{ path('app_article') }}" data-tip="Статьи">
        <svg viewBox="0 0 24 24"><path d="M6 3h9l3 3v15H6z"/><path d="M14 3v4h4"/><path d="M8 11h8"/><path d="M8 15h8"/><path d="M8 19h5"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').PARTNER_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_partner' ? 'active' : '' }}" href="{{ path('app_partner') }}" data-tip="Партнёрки">
        <svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.1 0l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1"/><path d="M14 11a5 5 0 0 0-7.1 0l-2 2a5 5 0 0 0 7.1 7.1l1.1-1.1"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').STATISTIC_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_statistic' ? 'active' : '' }}" href="{{ path('app_statistic') }}" data-tip="Статистика">
        <svg viewBox="0 0 24 24"><path d="M4 19V5"/><path d="M4 19h16"/><path d="M8 16v-5"/><path d="M12 16V8"/><path d="M16 16v-9"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').TASK_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_task' ? 'active' : '' }}" href="{{ path('app_task') }}" data-tip="Задачи">
        <svg viewBox="0 0 24 24"><path d="M9 11l2 2 4-5"/><rect x="4" y="4" width="16" height="16" rx="3"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').CALL_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_call' ? 'active' : '' }}" href="{{ path('app_call') }}" data-tip="Прозвон">
        <svg viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.4 2.1L8 9.7a16 16 0 0 0 6.3 6.3l1.3-1.3a2 2 0 0 1 2.1-.4c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2z"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').BASE_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_base' ? 'active' : '' }}" href="{{ path('app_base') }}" data-tip="Базы">
        <svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="7" ry="3"/><path d="M5 5v6c0 1.7 3.1 3 7 3s7-1.3 7-3V5"/><path d="M5 11v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"/></svg>
      </a>
    {% endif %}
    {% if is_granted(enum('App\\Security\\Enum\\Permission').AI_ACCESS.value) %}
      <a class="rail-btn {{ route starts with 'app_ai' ? 'active' : '' }}" href="{{ path('app_ai') }}" data-tip="AI">
        <svg viewBox="0 0 24 24"><rect x="5" y="7" width="14" height="12" rx="3"/><path d="M12 3v4"/><path d="M8 12h.01"/><path d="M16 12h.01"/><path d="M9 16h6"/></svg>
      </a>
    {% endif %}
  </div>

  <div class="rail-bottom">
    <div
      class="rail-user"
      data-tip="{{ user_service.user.name }} — {{ user_service.user.email }}">
      <span>{{ user_service.currentUserNameFirstLetter }}</span>
    </div>

    <form method="post" action="/logout">
      <button class="rail-btn" data-tip="Выйти" type="submit">
        <svg viewBox="0 0 24 24"><path d="M10 17l5-5-5-5"/><path d="M15 12H3"/><path d="M21 3v18"/></svg>
      </button>
    </form>
  </div>
</aside>